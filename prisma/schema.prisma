generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  pricePaise  Int
  imagePath   String
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
}

model Order {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  totalPaise   Int
  status       String
  shippingJson String
  createdAt    DateTime @default(now())
}
